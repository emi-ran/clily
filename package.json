{
  "name": "clily",
  "version": "0.1.0",
  "description": "Natural language to shell command CLI assistant",
  "type": "module",
  "bin": {
    "clily": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
    "cli",
    "gemini",
    "terminal",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@inquirer/prompts": "^7.8.4",
    "commander": "^14.0.1",
    "groq-sdk": "^0.30.0",
    "picocolors": "^1.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
