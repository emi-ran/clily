{
  "name": "@emiran/clily",
  "version": "0.1.1",
  "description": "CLI that turns natural language into safer shell commands",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clily": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.tr.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts",
    "prepack": "npm run check && npm run build && npm run test"
  },
  "keywords": [
    "cli",
    "command-line",
    "shell",
    "powershell",
    "bash",
    "zsh",
    "productivity",
    "developer-tools",
    "gemini",
    "groq",
    "openai",
    "openrouter",
    "terminal",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emi-ran/clily.git"
  },
  "homepage": "https://github.com/emi-ran/clily#readme",
  "bugs": {
    "url": "https://github.com/emi-ran/clily/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.54",
    "@ai-sdk/groq": "^3.0.31",
    "@ai-sdk/openai": "^3.0.49",
    "@google/genai": "^1.47.0",
    "@inquirer/prompts": "^7.8.4",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.141",
    "commander": "^14.0.1",
    "picocolors": "^1.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
